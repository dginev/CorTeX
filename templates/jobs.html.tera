{% extends "layout" %}
{% block head_extra %}{% if has_active %}<meta http-equiv="refresh" content="5">{% endif %}{% endblock head_extra %}
{% block content %}
<div class="center">
  <h1>Background jobs</h1>
  {% if has_active %}<p><em>Auto-refreshing every 5s while jobs are in flight…</em></p>{% endif %}
  <p>
    {% if active %}<a href="/jobs">All</a> &nbsp;·&nbsp; <strong>Pending only</strong>
    {% else %}<strong>All</strong> &nbsp;·&nbsp; <a href="/jobs?active=true">Pending only</a>{% endif %}
    &nbsp;·&nbsp; <a href="/api/jobs{% if active %}?active=true{% endif %}">JSON</a>
  </p>
  <form method="post" action="/reports/refresh" class="refresh-reports-form">
    <label>Force a report refresh (rebuilds the rollup behind every report; runs as a background job):</label>
    <button type="submit">Refresh reports now</button>
  </form>
  <br>
  {% if jobs | length == 0 %}
  <p>No {% if active %}pending {% endif %}jobs.</p>
  {% else %}
  <div class="row">
    <div class="col-md-1"></div>
    <div class="col-md-10">
      <table id="jobs-report" class="table table-striped">
        <thead>
          <tr>
            <th class="left">Kind</th>
            <th class="left">Actor</th>
            <th class="left">Health</th>
            <th class="right">Progress</th>
            <th class="right">Duration (s)</th>
            <th class="left">Started</th>
            <th class="left">Updated</th>
            <th class="right" title="Seconds since the last progress update; for a running job this is its heartbeat age — a large value flags a stalled job.">Idle (s)</th>
            <th class="left">Message</th>
            <th class="left">Detail</th>
          </tr>
        </thead>
        <tbody>
          {% for job in jobs %}
          <tr>
            <td class="left">{{job.kind}}</td>
            <td class="left">{{job.actor}}</td>
            <td class="left">{{job.health}}</td>
            <td class="right">{{job.progress_current}}{% if job.progress_total %}/{{job.progress_total}}{% endif %}</td>
            <td class="right">{{job.duration_seconds}}</td>
            <td class="left">{{job.created_at}}</td>
            <td class="left">{{job.updated_at}}</td>
            <td class="right">{% if job.health == "running" or job.health == "pending" %}{{job.seconds_since_update}}{% else %}—{% endif %}</td>
            <td class="left">{{job.message}}</td>
            <td class="left"><a href="/jobs/{{job.uuid}}">view</a></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    <div class="col-md-1"></div>
  </div>
  {% endif %}
</div>
{% endblock content %}
