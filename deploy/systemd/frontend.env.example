# CorTeX managed frontend environment -> install to /etc/cortex/frontend.env (chmod 600).
# Read by systemd as root, then the process drops to User=deyan.
# Rocket reads ROCKET_* via figment; cortex reads DATABASE_URL at runtime (no recompile).

ROCKET_ADDRESS=127.0.0.1
ROCKET_PORT=8000

# !! SET THIS to the PRODUCTION database before enabling the service.
# The hand-run frontend points at the load-test DB (cortex_load); choose deliberately.
DATABASE_URL=postgres://USER:PASSWORD@localhost/cortex

RUST_LOG=info
RUST_BACKTRACE=1
