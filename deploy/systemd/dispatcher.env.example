# CorTeX managed dispatcher environment -> install to /etc/cortex/dispatcher.env (chmod 600).
# Read by systemd as root, then the process drops to User=deyan.
# cortex reads DATABASE_URL + CORTEX_* at runtime (no recompile); see src/config.rs precedence.

# !! SET THIS to the database the conversion pipeline writes to, BEFORE enabling the service.
# For a live pipeline this is usually the SAME DB the frontend reads (so reports reflect new runs).
# The public showcase DB cortex_load is a static snapshot — point the dispatcher at production.
DATABASE_URL=postgres://USER:PASSWORD@localhost/cortex

# Optional dispatcher tuning (defaults in src/config.rs). Examples:
# CORTEX_DISPATCHER__TCP_KEEPALIVE_IDLE_SECONDS=120   # keep idle remote-worker conns alive
# CORTEX_DISPATCHER__SINK_WRITERS=4                   # /data archive-writer pool size
# CORTEX_DISPATCHER__MAX_IN_FLIGHT=5000               # backpressure threshold

RUST_LOG=info
RUST_BACKTRACE=1
