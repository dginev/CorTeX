# CorTeX latexml-oxide worker fleet — per-host config. Install to /etc/cortex/worker.env (chmod 600).
# Sourced by scripts/run_worker.sh (standalone or via cortex-worker.service). Every value is explicit
# on purpose: a wrong/absent worker parameter is a production-scale problem, so nothing defaults.

# Worker count = the empirical sweet spot: PHYSICAL cores + 1/8 (×1.125). NOT logical cores — the
# harness's CPU-derived default sizes to logical (128 on this 64-physical box) and over-commits to ~124.
#   64 physical -> 72   |   32 physical -> 36   |   16 physical -> 18
# Set this to THIS host's physical-core value before enabling the service.
WORKERS=72

# Service name MUST match the registered CorTeX service exactly (the sink discards a mismatch silently).
SERVICE=oxidized_tex_to_html

# Dispatcher ZMQ ports. Local dispatcher = 127.0.0.1; a remote fleet uses the dispatcher's LAN/Tailscale IP.
SOURCE_ADDRESS=tcp://127.0.0.1:51695
SINK_ADDRESS=tcp://127.0.0.1:51696

# Conversion profile (ar5iv | generic).
PROFILE=ar5iv

# Scratch dir for unpack/convert staging. MUST be disk-backed on a SEPARATE physical disk from the OS
# (here: /opt/cortex-scratch on the secondary NVMe). NOT a ramdisk — /dev/shm exhaustion under a large
# fleet truncates inputs → empty results (CorTeX KNOWN_ISSUES D-18). The worker honors TMPDIR via
# tempfile/env::temp_dir; run_worker.sh creates it if missing.
TMPDIR=/opt/cortex-scratch

# The rebuilt worker binary + its regenerated format dumps (set LATEXML_DUMP_DIR explicitly so dump
# resolution is machine-independent, not reliant on the binary's compiled-in dev-tree fallback).
WORKER_BIN=/home/deyan/git/latexml-oxide/target/release/cortex_worker
LATEXML_DUMP_DIR=/home/deyan/git/latexml-oxide/resources/dumps

# Memory/timeout guards are DELIBERATELY not set here — the binary's compiled defaults are the
# battle-hardened values (child-mem-limit 5632 / recycle 1408 / auto governor floor / timeout 180s).
# Do NOT add --child-mem-limit-mb 8192: that stale value spiked a 72-worker sweep to 207 GB (OOM).

RUST_LOG=info
RUST_BACKTRACE=1
