# CorTeX local environment — copy to `.env` and fill in your own values.
#
#   cp .env.example .env   &&   $EDITOR .env
#
# `.env` is gitignored: NEVER commit real credentials. It is loaded at runtime via `dotenvy`
# (highest-precedence override; see `src/config.rs` / the config precedence in CLAUDE.md). You can
# equivalently set these via `cortex.toml` or `CORTEX_`-prefixed env (`CORTEX_DATABASE__URL`).
#
# Production deployments do NOT use this file — the systemd units read an EnvironmentFile
# (e.g. /etc/cortex/frontend.env), kept off the box's working tree.

# Runtime database the frontend/dispatcher/CLI connect to (DB on NVMe, never /data — see CLAUDE.md).
DATABASE_URL=postgres://cortex:CHANGE_ME@localhost/cortex_dev

# Separate database used by the integration test suite (`cargo test`). Safe to reset; never point
# this at a populated/production DB.
TEST_DATABASE_URL=postgres://cortex_tester:CHANGE_ME@localhost/cortex_tester
