# CorTeX runtime configuration (example).
#
# Copy to `cortex.toml` and edit. Every value is optional — anything omitted falls back to the
# built-in default shown below. Precedence (lowest to highest):
#   defaults  <  cortex.toml  <  CORTEX_-prefixed env vars  <  legacy DATABASE_URL / TEST_DATABASE_URL
#
# Environment overrides nest with `__`, e.g.:
#   CORTEX_DATABASE__URL=postgres://user:pass@host/db
#   CORTEX_DISPATCHER__SOURCE_PORT=51695
#
# The historic DATABASE_URL / TEST_DATABASE_URL variables (e.g. from a local `.env`) remain
# authoritative when set, so existing deployments keep working without a cortex.toml.

[database]
url = "postgres://cortex:cortex@localhost/cortex"
test_url = "postgres://cortex_tester:cortex_tester@localhost/cortex_tester"

[dispatcher]
source_port = 51695
result_port = 51696
queue_size = 800       # must not exceed PostgreSQL's max_locks_per_transaction
message_size = 100000  # bytes per ZeroMQ chunk

# Frontend auth / secrets are NOT set here. Admin/API + rerun tokens live in the JSON token file
# (`config.json` in the CWD, or `CORTEX_AUTH_FILE`) — see `config.example.json`; manage it with
# `cortex set-admin-token` / `revoke-token`. (`CortexConfig.auth` is `#[serde(skip)]`, so figment
# never reads a `cortex.toml [auth]` section — one source of truth for tokens.)

[assets]
template_dir = "templates"   # use an absolute path for packaged installs (decouples from the CWD)
public_dir = "public"
